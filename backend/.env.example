# ── TuAgendaYa Backend — Variables de entorno ──────────────────
# Copiar a .env y completar valores reales:
#   cp .env.example .env

# ────────────────────────────────────────────────────────────────
# SERVIDOR
# ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development   # "production" en producción

# Frontend URL (para CORS y links en emails y OAuth)
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# ────────────────────────────────────────────────────────────────
# JWT — OBLIGATORIO
# ────────────────────────────────────────────────────────────────
# Generá un secreto seguro: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=tuagendaya-super-secret-dev-CAMBIA-ESTO-EN-PRODUCCION

# ────────────────────────────────────────────────────────────────
# SMTP / EMAILS
# ────────────────────────────────────────────────────────────────
# Sin configurar → los emails se imprimen en consola (modo dev). Perfecto para desarrollo.
# Para producción, configurá un proveedor SMTP real.
#
# ── OPCIÓN 1: Resend (recomendado, gratis hasta 3000 emails/mes)
#   1. Registrarse en https://resend.com
#   2. Verificar tu dominio en Resend → Domains
#   3. Obtener API key en Resend → API Keys
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxx    ← tu API key de Resend
#   SMTP_FROM=TuAgendaYa <no-reply@tudominio.com>
#
# ── OPCIÓN 2: SendGrid
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxxxxxx    ← tu API key de SendGrid
#   SMTP_FROM=TuAgendaYa <no-reply@tudominio.com>
#
# ── OPCIÓN 3: Mailtrap (para testing, emails no llegan al destinatario)
#   Crear cuenta en https://mailtrap.io → Inboxes → SMTP Settings
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=<mailtrap-user>
#   SMTP_PASS=<mailtrap-pass>
#   SMTP_FROM=TuAgendaYa <no-reply@tuagendaya.app>
#
# ── OPCIÓN 4: Gmail (cuenta personal, limitado a 500 emails/día)
#   1. Activar "Contraseñas de aplicación" en tu cuenta Google
#      https://myaccount.google.com/apppasswords
#   2. Usar la contraseña de app (16 caracteres) como SMTP_PASS
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=tu@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx    ← contraseña de app (sin espacios)
#   SMTP_FROM=TuAgendaYa <tu@gmail.com>

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TuAgendaYa <no-reply@tuagendaya.app>

# ────────────────────────────────────────────────────────────────
# GOOGLE CALENDAR (opcional)
# ────────────────────────────────────────────────────────────────
# Pasos para configurar:
#   1. Ir a https://console.cloud.google.com/apis/credentials
#   2. Crear proyecto → Habilitar Google Calendar API
#   3. Crear credenciales → OAuth 2.0 Client ID → Aplicación web
#   4. Agregar URI autorizado de redirección: http://localhost:3001/api/calendar/callback
#   5. Para producción agregar también: https://tudominio.com/api/calendar/callback
#   6. Copiar Client ID y Client Secret aquí

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# ────────────────────────────────────────────────────────────────
# PANEL SUPERADMIN — OBLIGATORIO para usar /admin
# ────────────────────────────────────────────────────────────────
# Acceso en: http://localhost:5173/admin/login
# Si no se configuran, el endpoint /api/admin/login devuelve 503.
#
# Elegí un email y contraseña seguros (no uses los del profesional).
# La contraseña se compara directamente (no hasheada), usá una larga.
# Generá una segura: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"

ADMIN_EMAIL=admin@tuagendaya.com
ADMIN_PASSWORD=cambia-esto-por-una-contraseña-segura