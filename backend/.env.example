# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Obligatorio en producción (mín. 32 caracteres). Generá uno con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Orígenes permitidos (separados por coma). En producción es obligatorio.
# Ejemplo: https://tuagendaya.onrender.com,https://www.tudominio.com
CORS_ORIGIN=http://localhost:5173

# ─── Base de datos (SQLite persistente) ───────────────────────
# Desarrollo: se usa backend/tuagendaya.db por defecto
# Render: montar disco en /var/data y usar:
DATABASE_PATH=

# ─── Admin inicial (solo se crea si no existe) ────────────────
ADMIN_EMAIL=admin@tuagendaya.com
ADMIN_PASSWORD=

# En producción NO crear usuario demo (maria@tuagendaya.com)
# SEED_DEMO=true

# ─── WhatsApp Cloud API (Meta) — recomendado ────────────────
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0

# ─── Twilio WhatsApp (alternativa) ────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
